# =============================================================================
# .env.example — Document environment variables for this project
# =============================================================================
# Copy this file to .env and fill in real values:
#
#   cp .env.example .env
#
# .env is listed in .gitignore and will NEVER be committed.
# .env.example contains NO real credentials and IS committed as a template.
# =============================================================================

# Host port Vault's API and UI will be exposed on (default: 8200)
VAULT_HOST_PORT=8200

# Vault address used by the CLI on the host machine
# Replace <host-ip> with the actual IP or hostname of your Ubuntu host
VAULT_ADDR=http://<host-ip>:8200

# (Optional) Root token — populate locally for scripting convenience ONLY.
# Never set this in production. Revoke the root token after initial setup.
# VAULT_TOKEN=hvs.<your-root-token>
